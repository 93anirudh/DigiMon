{
  "name": "digimon",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xyflow/react": "^12.3.5",
    "better-sqlite3": "^12.8.0",
    "langchain": "^1.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.5.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "com.digimon.app",
    "productName": "DigiMon",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "mcp_config.json",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "mcp_config.json",
        "to": "mcp_config.json"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico",
      "artifactName": "DigiMon.exe"
    },
    "portable": {
      "artifactName": "DigiMon.exe"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
